// Cluster knobs for the `arrhenius` profile — override on the CLI, e.g.
//   -profile arrhenius --gpu_account <proj> --gpu_sif /allowed/path/pinn-gpu.sif
params.gpu_sif     = 'pinn-gpu.sif'  // GPU apptainer image (absolute path on the cluster)
params.cpu_sif     = 'pinn-cpu.sif'  // CPU image used for data prep
params.gpu_gres    = 'gpu:1'         // --gres value; set to the GPU type if required
params.gpu_account = ''              // slurm account (-A) for training; empty = cluster default
params.cpu_account = ''              // slurm account (-A) for data prep; empty = cluster default
params.train_time  = '2d'            // GPU walltime; keep under the GrpTRESRunMins cap
params.prep_time   = '4h'            // CPU walltime for data prep

profiles {
  docker {
    singularity.enabled = true
    process.container = "docker://tecatuu/pinn:master-gpu"
  }
  local {
    process.beforeScript = """
    module load TensorFlow/2.7.1-foss-2021b-CUDA-11.4.1.lua
    source PATH/TO/PYTHON/VENV
    """
  }
  benchmark {
    params.setup = [
      qm9: [
        pot: "{*, nofrc}"
      ],
      rmd17: [
        pot: "{*, frc}"
      ]
    ]
  }
  pinet2_qm9_dipole {
    params.setup = [
      qm9: [
        pot: "{pinet2-dipole.yml,}"
      ]
    ]
    params.train_steps = 3000000
    params.train_total = -1
  }
  regression {
    params.setup = [
      qm9: [
        pot: "{*, nofrc}"
      ],
      rmd17: [
        pot: "{*, frc}"
      ]
    ]
    params.rmd17_tags = "aspirin,toluene,uracil"
    params.train_steps = 10000
  }
  alvis {
    process.scratch = false
    process.time = '6d'
    process.clusterOptions = '--gres=gpu:A100:1'
    executor{
      name = 'slurm'
      queueSize = 20
      submitRateLimit = '120 min'
    }
  }
  // Arrhenius (NSC): training on the GPU partition (default), data prep
  // (gen_*/get_qm7b) on the internet-enabled CPU partition. Both via apptainer.
  arrhenius {
    apptainer {
      enabled    = true
      autoMounts = true
    }
    executor {
      name            = 'slurm'
      queueSize       = 20
      submitRateLimit = '20/1min'
    }
    process {
      executor         = 'slurm'
      queue            = 'gpu'
      container        = params.gpu_sif
      containerOptions = '--nv'
      clusterOptions   = (params.gpu_account ? "-A ${params.gpu_account} " : '') + "--gres=${params.gpu_gres}"
      cpus             = 16
      time             = params.train_time
      withName: 'gen_.*|get_qm7b' {
        queue            = 'cpu'
        container        = params.cpu_sif
        containerOptions = ''
        clusterOptions   = params.cpu_account ? "-A ${params.cpu_account}" : ''
        cpus             = 8
        time             = params.prep_time
      }
    }
  }
}

manifest.mainScript = 'nextflow/main.nf'
